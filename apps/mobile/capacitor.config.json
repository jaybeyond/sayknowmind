{
  "appId": "com.sayknowmind.mobile",
  "appName": "SayknowMind",
  "webDir": "../web/.next",
  "server": {
    "url": "http://localhost:3000",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0A0A0A",
      "showSpinner": true,
      "spinnerColor": "#00E5FF"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#00E5FF"
    },
    "Share": {}
  },
  "android": {
    "buildOptions": {
      "keystorePath": null,
      "keystoreAlias": null
    }
  },
  "ios": {
    "contentInset": "automatic"
  }
}
