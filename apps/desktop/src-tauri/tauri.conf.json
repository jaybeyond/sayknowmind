{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "SayknowMind",
  "version": "0.1.0",
  "identifier": "com.sayknowmind.desktop",
  "build": {
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bash scripts/build-desktop.sh",
    "beforeDevCommand": ""
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self' http://localhost:3457; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3457; style-src 'self' 'unsafe-inline' http://localhost:3457; img-src 'self' data: blob: http: https:; connect-src 'self' http://localhost:3457 http://127.0.0.1:3458 http://localhost:11434 https://mind.sayknow.ai ws://localhost:*; font-src 'self' data: http://localhost:3457"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": {
      "resources/web-standalone": "web-standalone"
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://releases.sayknow.ai/{{target}}/{{arch}}/{{current_version}}"],
      "dialog": true,
      "pubkey": ""
    },
    "global-shortcut": null
  }
}
