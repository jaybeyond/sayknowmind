# SayKnow AI Server - Environment Configuration Template
# Copy this file to .env and fill in your actual values

NODE_ENV=development
PORT=4000

# Development mode: skip RSA authentication (set to false in production)
SKIP_AUTH=true

# AI API Key (backend → AI server authentication)
# Generate a secure random key: openssl rand -hex 32
AI_API_KEY=your-secure-random-key-here

# OpenRouter (Primary - free models)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
USE_OPENROUTER=true

# Z.AI (optional)
USE_ZAI=false
ZAI_API_KEY=your-zai-api-key

# Upstage (optional)
USE_UPSTAGE=false
UPSTAGE_API_KEY=your-upstage-api-key

# NVIDIA (optional)
USE_NVIDIA=false
NVIDIA_API_KEY=your-nvidia-api-key

# Cloudflare Workers AI (optional)
USE_CLOUDFLARE=false
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Venice AI (paid fallback - uncensored)
# Get your API key from: https://venice.ai
USE_VENICE=false
VENICE_API_KEY=your-venice-api-key

# Grok (xAI) - paid fallback
# Get your API key from: https://x.ai
USE_GROK=false
XAI_API_KEY=your-xai-api-key

# Redis (memory system - optional but recommended)
# Local: redis://localhost:6379
# Railway: Use Railway's Redis URL
REDIS_URL=redis://localhost:6379

# OCR Service (optional)
OCR_ENDPOINT=http://localhost:8000

# SearXNG Search (optional but recommended)
# Deploy your own: https://github.com/searxng/searxng
SEARXNG_URL=http://localhost:8080

# CORS - allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3002,http://localhost:3100

# RSA Keys (production only - base64 encoded)
# Generate keys: npm run generate-keys
# PRIVATE_KEY=base64_encoded_private_key
# PUBLIC_KEY=base64_encoded_public_key
# CLIENT_PUBLIC_KEY=base64_encoded_client_public_key

# Local Model URLs (optional - for self-hosted models)
# SAYKNOWAI_PRO_URL=http://localhost:11434
# SAYKNOWAI_FLASH_URL=http://localhost:11435
# OLLAMA_URL=http://localhost:11434
