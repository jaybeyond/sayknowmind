# ============================================
# SayknowMind v0.1.0 Environment Configuration
# ============================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_PORT=5432

# Authentication (better-auth)
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database URL (used by better-auth)
DATABASE_URL=postgres://postgres:changeme-in-production@localhost:5432/sayknowmind

# Encryption (AES-256-GCM per-user data encryption)
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# AI Server (ingestion pipeline uses this for summary/entity extraction)
AI_SERVER_URL=http://localhost:4000
AI_API_KEY=

# EdgeQuake RAG Engine (search & knowledge graph)
EDGEQUAKE_URL=http://localhost:8080
EDGEQUAKE_API_KEY=

# Service Ports
WEB_PORT=3000
DASHBOARD_PORT=3001
AI_SERVER_PORT=4000
EDGEQUAKE_PORT=8080
MCP_PORT=8082
OLLAMA_PORT=11434
SEARXNG_PORT=8888

# LLM Provider (ollama | openai)
LLM_PROVIDER=ollama
LLM_MODEL=Qwen/Qwen3.5-0.8B

# API Keys (at least one required for external LLM)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Security
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
REQUIRE_EMAIL_VERIFICATION=false

# Cloud Relay Sync (optional — encrypted temporary storage for offline sync)
RELAY_URL=http://localhost:3200
RELAY_SHARED_SECRET=generate-with-openssl-rand-hex-32
RELAY_PORT=3200

# Deploy Mode (cloud | desktop | auto)
# cloud: all AI via external APIs, no Ollama
# desktop: local Ollama + models, users download from Settings
# auto (default): detect Tauri runtime → desktop, otherwise → cloud
NEXT_PUBLIC_DEPLOY_MODE=auto

# Cloud Embedding (used when DEPLOY_MODE=cloud)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Mode
PRIVATE_MODE=true

# Logging
RUST_LOG=info
NODE_ENV=production

# IPFS Kubo (Decentralized Storage for Shared Mode)
IPFS_KUBO_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8180/ipfs
IPFS_API_PORT=5001
IPFS_GATEWAY_PORT=8180

# Syncthing (Optional — Device Sync)
SYNCTHING_API=http://localhost:8384
SYNCTHING_API_KEY=

# Tailscale (Optional — Peer Discovery)
TAILSCALE_API=http://localhost:41112

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_MS=86400000

# MCP Server
MCP_SERVER_URL=http://localhost:8082

# Telegram Bot Integration (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32
