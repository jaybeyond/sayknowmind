# ============================================
# SayknowMind v0.1.0 Environment Configuration
# ============================================

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_PORT=5432

# Authentication
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Service Ports
WEB_PORT=3000
DASHBOARD_PORT=3001
AI_SERVER_PORT=4000
EDGEQUAKE_PORT=8080
MCP_PORT=8082
OLLAMA_PORT=11434
SEARXNG_PORT=8888

# LLM Provider (ollama | openai)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:0.5b

# API Keys (at least one required for external LLM)
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Mode
PRIVATE_MODE=true

# Logging
RUST_LOG=info
NODE_ENV=production
